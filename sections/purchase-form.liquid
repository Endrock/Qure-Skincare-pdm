<script src="{{ 'jquery.min.js' | asset_url }}"></script>
<script src="{{ '__app-purchase-form.js' | asset_url }}" data-form="{{ section.settings.form_name }}" data-section="{{ section.id }}" defer></script>
{%- schema -%}
{
    "name":"t:sections.purchase-form.name",
    "class":"purchase-form",
    "settings":[
        {
            "type": "text",
            "id": "heading",
            "label": "t:common.header"
        },
        {
            "type": "text",
            "id": "text",
            "label": "t:common.text"
        },
        {
            "type": "checkbox",
            "id": "hide_product_types",
            "label": "t:sections.purchase-form.settings.hide_product_types",
            "default": false
        },
        {
            "type": "checkbox",
            "id": "hide_payment_types",
            "label": "t:sections.purchase-form.settings.hide_payment_types",
            "default": false
        },
        {
            "type": "image_picker",
            "id": "image",
            "label": "t:common.image.label"
        },
        {
            "type": "image_picker",
            "id": "icon_image1",
            "label": "t:common.image.label"
        },
        {
            "type": "text",
            "id": "icon_text1",
            "label": "t:common.text.label"
        },
        {
            "type": "image_picker",
            "id": "icon_image2",
            "label": "t:common.image.label"
        },
        {
            "type": "text",
            "id": "icon_text2",
            "label": "t:common.text.label"
        },
        {
            "type": "image_picker",
            "id": "icon_image3",
            "label": "t:common.image.label"
        },
        {
            "type": "text",
            "id": "icon_text3",
            "label": "t:common.text.label"
        },
        {
            "type": "richtext",
            "id": "bottom_text",
            "label": "t:common.text.label"
        },
        {
            "type": "text",
            "id": "form_name",
            "label": "t:sections.purchase-form.settings.form_name",
            "default": "purchase-form"
        }
    ],
    "blocks":[
        {
            "type": "nextships",
            "name": "t:common.nextships",
            "limit": 1,
            "settings": [
                {
                    "type": "text",
                    "id": "date",
                    "label": "t:common.date",
                    "default": "25 September"
                },
                {
                    "type": "range",
                    "id": "percent",
                    "min": 0,
                    "max": 100,
                    "step": 1,
                    "unit": "%",
                    "label": "t:common.percent",
                    "default": 48
                },
                {
                    "type": "text",
                    "id": "date_soldout",
                    "label": "t:common.soldout",
                    "default": "28 July"
                },
                {
                    "type": "text",
                    "id": "date_reserved",
                    "label": "t:common.reserved",
                    "default": "3 August"
                }
            ]
        },
        {
            "type": "type",
            "limit": 3,
            "name": "t:common.type",
            "settings": [
                {
                    "type": "header",
                    "content": "TYPE"
                }
            ]
        },
        {
            "type": "product_type",
            "name": "t:common.product-type",
            "limit": 3,
            "settings": [
                {
                    "type": "text",
                    "id": "heading",
                    "label": "t:common.header"
                },
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": "t:common.image"
                },
                {
                    "type": "checkbox",
                    "id": "preselected",
                    "label": "t:common.preselect",
                    "default": false
                }
            ]
        },
        {
            "type": "product",
            "name": "t:common.product",
            "limit": 9,
            "settings": [
                {
                    "type": "product",
                    "id": "product",
                    "label": "t:common.product"
                },
                {
                    "type": "checkbox",
                    "id": "preselected",
                    "label": "t:common.preselect",
                    "default": false
                },
                {
                    "type": "text",
                    "id": "heading",
                    "label": "t:common.header"
                },
                {
                    "type": "text",
                    "id": "subheading",
                    "label": "t:common.subheader"
                },
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": "t:common.image"
                },
                {
                    "type": "checkbox",
                    "id": "soldout",
                    "label": "t:common.soldout",
                    "default": false
                },
                {
                    "type": "checkbox",
                    "id": "preorder",
                    "label": "t:common.preorder",
                    "default": false
                },
                {
                    "type": "richtext",
                    "id": "preorder_text",
                    "label": "t:sections.purchase-form.blocks.product.settings.preorder_text"
                },
                {
                    "type": "text",
                    "id": "preorder_date_soldout",
                    "label": "t:sections.purchase-form.blocks.product.settings.preorder_date_soldout"
                },
                {
                    "type": "text",
                    "id": "preorder_date_reserved",
                    "label": "t:sections.purchase-form.blocks.product.settings.preorder_date_reserved"
                },
                {
                    "type": "range",
                    "id": "preorder_percent",
                    "min": 0,
                    "max": 100,
                    "step": 1,
                    "unit": "%",
                    "label": "t:common.percent",
                    "default": 55
                },
                {
                    "type": "richtext",
                    "id": "included_text",
                    "label": "t:sections.purchase-form.blocks.product.settings.included_text"
                }
            ]
        },
        {
            "type": "payment_type",
            "name": "t:common.payment",
            "limit": 2,
            "settings": [
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": "t:common.image"
                }
            ]
        }
    ],
    "presets":[
        {
            "name":"t:sections.purchase-form.name"
        }
    ]
}
{%- endschema -%}