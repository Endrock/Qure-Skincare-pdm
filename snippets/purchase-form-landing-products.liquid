{% endcapture %}

<div class="patch__product-variants max-w-ctm" style="--max-w-ctm:500px">
    <div class="patch__variant-label mb-15 mt-20">{{ 'purchase-form.settings.select-product' | t }}</div>
    {% render 'purchase-form-landing-products-item' array: __idsArray1, preorder_box: preorder_box %}
    {% render 'purchase-form-landing-products-item' array: __idsArray2, preorder_box: preorder_box %}
    {% render 'purchase-form-landing-products-item' array: __idsArray3, preorder_box: preorder_box %}

    <div id="{{ section.settings.form_name }}-body-{{ section.id }}"></div>
</div>