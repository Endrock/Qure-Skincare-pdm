                    <p class="mb-0">1 Months</p>
                    <p class="fs-14 mb-15">(2 treatments)</p>
                    <div class="qure__supply-price">
                        <span class="qure__supply-price-reg">$XXX</span>
                    </div>
                </div>
            </label>
        </div>
    </div>
    <div class="tab-content mt-25" id="myTabContent">
        <div class="tab-pane fade show active" id="m-3-tab-pane" role="tabpanel"
            aria-labelledby="m-3-tab" tabindex="0">
            <div class="qure_bundle-accorion">
                <button class="qure_bundle-btn collapsed" type="button"
                    data-bs-toggle="collapse" data-bs-target="#3monthCollapse"
                    aria-expanded="false" aria-controls="3monthCollapse">
                    What is in the 3 Month Supply bundle?
                </button>
                <div id="3monthCollapse" class="qure_bundle-collapse collapse"
                    data-bs-parent="#accordionExample">
                    <div class="accordion-body mt-12">
                        <ul class="qure__list-check">
                            <li>1 Micro-Infusion devices (valued at $80)</li>
                            <li>5 clinical-grade micro-needling heads (valued at $50)</li>
                            <li>6 clinically formulated 4ml serums to treat your specific
                                skin
                                concerns (valued at $120)</li>
                            <li>Worldwide shipping (valued at $25)</li>
                            <li>Risk-free 90 day money-back guarantee to trial</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
        <div class="tab-pane fade" id="m-2-tab-pane" role="tabpanel"
            aria-labelledby="m-2-tab" tabindex="0">
            <div class="qure_bundle-accorion">
                <button class="qure_bundle-btn collapsed" type="button"
                    data-bs-toggle="collapse" data-bs-target="#2monthCollapse"
                    aria-expanded="false" aria-controls="2monthCollapse">
