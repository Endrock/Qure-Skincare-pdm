{% capture preorder_box %}
    {% render 'product-page-next-ships', section: section, class: 'hide preorder_box' %}
{% endcapture %}

{% if section.settings.hide_product_types == true and section.settings.hide_payment_types == true %}
    {% comment %} here need to hide step {% endcomment %}
{% endif %}


<div class="qure__bundle-steps">
    <div class="qure-bundle-stps-title mb-16">{{ 'purchase-form.settings.select-product' | t }}</div>
        {% render 'purchase-form-product' array: __idsArray1, preorder_box: preorder_box %}
        {% render 'purchase-form-product' array: __idsArray2, preorder_box: preorder_box %}
        {% render 'purchase-form-product' array: __idsArray3, preorder_box: preorder_box %}
     <div id="{{ section.settings.form_name }}-body-{{ section.id }}"></div>
</div> 



{% comment %} 
<div class="qure-bundle-container" style="--col-gap: 10px;--col-gap-mb:10px">
    <div class="bundle-supply d-flex col-gap align-items-end" id="myTab" role="tablist">
        <div class="qure-supply-item col" role="presentation">
            <input type="radio" name="supply" id="three-months" checked="">
            <label for="three-months" class="supply-link active pt-0" id="m-3-tab"
                data-bs-toggle="tab" data-bs-target="#m-3-tab-pane" type="button" role="tab"
                aria-controls="m-3-tab-pane" aria-selected="true">
                <div class="qure-best-value">Best Value <i
                        class="fa-sharp fa-solid fa-star-sharp"></i></div>
                <div class="qure__supply-img"><img
                        src="https://qureskincaredns-main.com/sections/isolated/micro-infusion-pdp/images/3_month_mixed.webp"
                        class="img-fluid"></div>
                <div class="qure__supply-content">
                    <p class="mb-0">3 Months</p>
                    <p class="fs-14 mb-15">(6 treatments)</p>
                    <div class="qure__supply-price">
                        <span class="qure__supply-price-sale">$XXX</span>
                        <span class="qure__supply-price-reg-sale">$XXX</span>
                    </div>
                    <span class="qure__supply-badge">38% OFF</span>
                </div>
            </label>
        </div>
        <div class="qure-supply-item col" role="presentation">
            <input type="radio" name="supply" id="two-months">
            <label for="two-months" class="supply-link" id="m-2-tab" data-bs-toggle="tab"
                data-bs-target="#m-2-tab-pane" type="button" role="tab"
                aria-controls="m-2-tab-pane" aria-selected="false" tabindex="-1">
                <div class="qure__supply-img"><img
                        src="https://qureskincaredns-main.com/sections/isolated/micro-infusion-pdp/images/2_month_mixed.webp"
                        class="img-fluid"></div>
                <div class="qure__supply-content">
                    <p class="mb-0">2 Months</p>
                    <p class="fs-14 mb-15">(4 treatments)</p>
                    <div class="qure__supply-price">
                        <span class="qure__supply-price-sale">$XXX</span>
                        <span class="qure__supply-price-reg-sale">$XXX</span>
                    </div>
                    <span class="qure__supply-badge">19% OFF</span>
                </div>
            </label>
        </div>
        <div class="qure-supply-item col" role="presentation">
            <input type="radio" name="supply" id="one-months">
            <label for="one-months" class="supply-link" id="m-1-tab" data-bs-toggle="tab"
                data-bs-target="#m-1-tab-pane" type="button" role="tab"
                aria-controls="m-1-tab-pane" aria-selected="false" tabindex="-1">
                <div class="qure__supply-img"><img
                        src="https://qureskincaredns-main.com/sections/isolated/micro-infusion-pdp/images/1_month_mixed.webp"
