{% doc %}
Renders a blog posts
{% enddoc %}

<h2 class="banner-text--heading mb-30">{{ 'blog.choose.header' | t }}</h2>
<div class="d-flex flex-column flex-md-row gap-4 gap-md-5 mw" style="--mw:648px;">
    {% for link in linklists.blog-menu.links offset:1 %}
        <a href="{{ link.url }}" class="choose_blog_topic position-relative">
            {% case forloop.index %}
                {% when 1 %}  
                    <img src="https://qureskincaredns-main.com/sections/isolated/blogs/images/choose_blog_1.webp" alt="{{ link.title | escape }}" class="img-fluid d-none d-md-block">
                    <img src="https://qureskincaredns-main.com/sections/isolated/blogs/images/choose_blog_1_mob.webp" alt="{{ link.title | escape }}" class="img-fluid d-md-none">
                {% when 2 %}
                    <img src="https://qureskincaredns-main.com/sections/isolated/blogs/images/choose_blog_2.webp" alt="{{ link.title | escape }}" class="img-fluid d-none d-md-block">
                    <img src="https://qureskincaredns-main.com/sections/isolated/blogs/images/choose_blog_2_mob.webp" alt="{{ link.title | escape }}" class="img-fluid d-md-none">
                {% when 3 %}
                    <img src="https://qureskincaredns-main.com/sections/isolated/blogs/images/choose_blog_3.webp" alt="{{ link.title | escape }}" class="img-fluid d-none d-md-block">
                    <img src="https://qureskincaredns-main.com/sections/isolated/blogs/images/choose_blog_3_mob.webp" alt="{{ link.title | escape }}" class="img-fluid d-md-none">
            {% endcase %}
            <h6>{{ link.title }}</h6>
        </a>
    {% endfor %}
</div>
<div class="articles mt-40">
    <h2 class="banner-text--heading mb-30">{{ blogs[blog_handle].title }}</h2>
    {%- paginate blogs[blog_handle].articles by limit -%}
        <div class="row g-5">
            {% for article in blogs[blog_handle].articles %}
                <div class="col-md-6 col-lg-4">
                    <div class="article">
                        {% if article.image != blank %}
                            <div class="article_img position-relative"> <img src="{{ article.image | image_url }}" alt="{{ article.image.alt | escape }}" class="img-fluid w-100">
                                <p class="tag_name">#{{ blog.handle }}</p>
                            </div>
                        {% endif %}
                        <div class="article_content border border-top-0 p-24">
                            <div class="d-flex justify-content-between mb-15">
                                <div class="article_date">
                                    <p>{{ article.published_at | date: '%B %d, %Y' }}</p>
                                </div>
                                <div class="read_time">
                                    <p>{{ 'blog.choose.read_time' | t }}</p>
                                </div>
                            </div>
                            <div class="d-flex flex-column justify-content-between gap-5 title_bt_wrap">
                                <p class="article_title">{{ article.title | truncatewords: 8 }}</p>
                                <a href="{{ article.url }}" class="btn">{{ 'blog.choose.read_more' | t }}</a>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
            {%- if paginate.pages > 1 -%}
                {% render 'blog-pagination', paginate: paginate %}
            {%- endif -%}
        </div>
    {%- endpaginate -%}
</div>

