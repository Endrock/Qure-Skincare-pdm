{% if array != blank %}

    <style>
        .hide {
            display: none; 
        }
    </style>

    {% capture preorder-box-items %}{% endcapture %}
    {% capture product-included-dropdown %}{% endcapture %}

    {%- for __id in array -%}
        {% assign block = section.blocks | where: "id", __id | first %}
        {% if block.type == 'product_type' %}
            {% assign product_type_title = block.settings.heading | strip_newlines | strip | replace: ' ', '' | replace: ',', '_' | downcase %}
        {% endif %}
    {%- endfor -%}

    <template id="{{ section.settings.form_name }}-source-{{ section.id }}-{{ product_type_title }}">
        <div class="step_content" id="{{ section.id }}-{{ product_type_title }}">
            <div class="qure-bundle-container step_conten_blocks" style="--col-gap: 10px;--col-gap-mb:10px">
                <div class="bundle-supply d-flex col-gap align-items-end" id="myTab" role="tablist">

                    {% assign array_count = array.size %}

                    {%- for __id in array -%}
                        {% assign block = section.blocks | where: "id", __id | first %}
                        {% if block.type == 'product' %}
                            {% assign product = all_products[block.settings.product] %}
                            {% if product != blank and product.available %}
                                {% assign product_id = product.id %}
                                {% assign product_variant_id = product.variants.first.id %}
                                {% assign product_price_divided = product.price | divided_by: 4 %}
                                {% assign discount_percentage = product.price | times: 1.0 | divided_by: product.compare_at_price | minus: 1 | abs | times: 100 | ceil %}
                                {% assign product_title_tag = block.settings.heading | strip_newlines | strip | replace: ' ', '' | replace: ',', '_' | downcase %}
                                {% assign product_price = product.price | money_without_trailing_zeros %}
                                {% assign product_price_compare = product.compare_at_price | money_without_trailing_zeros %}

                                {% assign array_count = array_count |  minus: 1 %}
                                {% assign product_type = array_count %}
                                
                                {% if product_price_compare == blank %}
                                    {% assign discount_percentage = blank %}
                                {% endif %}

                                {% capture product-included-dropdown %}
                                    {{ product-included-dropdown }}
                                    <div class="tab-pane fade" id="{{ block.id }}-tabitem" role="tabpanel" aria-labelledby="{{ block.id }}-tab" tabindex="0">
                                        <div class="qure_bundle-accorion">
                                            <button class="qure_bundle-btn collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#{{ block.id }}-collapse" aria-expanded="false" aria-controls="{{ block.id }}-collapse">
                                                What is in the {{ block.settings.heading }}?
                                            </button>
                                            <div id="{{ block.id }}-collapse" class="qure_bundle-collapse collapse" data-bs-parent="#accordionExample">
                                                <div class="accordion-body mt-12">
                                                    {{ block.settings.included_text |  replace:  '<ul>', '<ul class="qure__list-check">' }}
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                {% endcapture %}

                                {% capture data-per %}{{ 'purchase-form.settings.buy-button-label' | t }} {% if discount_percentage != blank %} {{ 'purchase-form.settings.save' | t }} {{ discount_percentage }}%{% endif %}{% endcapture %}

                                {% if block.settings.preorder == true %}
                                    {% capture data-per %}{{ 'purchase-form.settings.reserve-button-label' | t }} {% if discount_percentage != blank %} {{ 'purchase-form.settings.save' | t }} {{ discount_percentage }}%{% endif %}{% endcapture %}
                                {% endif %}

                                {% if block.settings.soldout == true %}
                                    {% capture data-per %}{{ 'purchase-form.settings.soldout-button-label' | t }}{% endcapture %}
                                {% endif %}

                                <div class="qure-supply-item col planBlock" role="presentation" href="javascript:void(0)"
                                    data-block-id="{{ block.id }}"
                                    data-tab="tab_{{ product_title_tag }}" 
                                    data-pay="{{ product_price_divided | money_without_trailing_zeros }}" 
                                    data-per="{{ data-per }}" 
                                    data-image="{{ block.settings.image | img_url: 'master' }}" 
                                    data-product_variant_id="{{ product_variant_id }}" 
                                    data-soldout="{{ block.settings.soldout }}" 
                                    data-preorder="{{ block.settings.preorder }}" 
                                    data-product-type="{{ product_type }}"
                                    data-product-name="{{ block.settings.heading | escape }}",
                                    data-product-price="{{ product_price }}">

                                    <input type="radio" name="monthlyPlan_{{ section.settings.form_name }}" id="{{ section.id }}-{{ product_title_tag }}"{% if block.settings.preselected == true %} checked{% endif %}>

                                    <label for="{{ section.id }}-{{ product_title_tag }}" class="supply-link active pt-0" id="{{ block.id }}-tab"
                                        data-bs-toggle="tab" data-bs-target="#{{ block.id }}-tabitem" type="button" role="tab"
                                        aria-controls="{{ block.id }}-tabitem" aria-selected="true">
                                        
                                        {% if product_type == 3 %}
                                            <div class="qure-best-value">{{ 'purchase-form.settings.best' | t }} <i class="fa-sharp fa-solid fa-star-sharp"></i></div>
                                        {% endif %}

                                        {% if block.settings.image != blank %}
                                            <div class="qure__supply-img">
                                                <img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.image.alt | escape }}" class="img-fluid">
                                            </div>
                                        {% else %}
                                            <br />
                                        {% endif %}

                                        <div class="qure__supply-content">
                                            <p class="mb-0">{{ block.settings.heading }}</p>
                                            <p class="fs-14 mb-15">{{ block.settings.subheading }}</p>
                                            <div class="qure__supply-price">
                                                {% if product_price_compare != blank %}
                                                    <span class="qure__supply-price-sale regular_price">{{ product_price_compare }}</span>
                                                    <span class="qure__supply-price-reg-sale sale_price">{{ product_price }}</span>
                                                {% else %}
                                                    <span class="qure__supply-price-reg sale_price">{{ product_price }}</span>
                                                {% endif %}
                                            </div>
                                             {% if discount_percentage != blank %}
                                                <span class="qure__supply-badge">{{ discount_percentage }}% {{ 'purchase-form.settings.off' | t }}</span>
                                            {% endif %}
                                        </div>
                                    </label>
                                </div>


                                {% if block.settings.preorder == true %}
                                    
                                    {% capture preorder-box-items %}{{ preorder-box-items }}<div class="{{ section.settings.form_name }}-preorder-box-item {{ section.settings.form_name }}-preorder-box__{{ product_variant_id }}"></div>{% endcapture %}
                                    
                                    {% if block.settings.preorder_text != blank %}
                                        <span class="{{ section.settings.form_name }}-product-preorder-text__{{ product_variant_id }} hide">{{ block.settings.preorder_text }}</span>
                                    {% endif %}
                                    {% if block.settings.preorder_date_soldout != blank %}
                                        <span class="{{ section.settings.form_name }}-product-preorder_date_soldout__{{ product_variant_id }} hide">{{ block.settings.preorder_date_soldout }}</span>
                                    {% endif %}
                                    {% if block.settings.preorder_date_reserved != blank %}
                                        <span class="{{ section.settings.form_name }}-product-preorder_date_reserved__{{ product_variant_id }} hide">{{ block.settings.preorder_date_reserved }}</span>
                                    {% endif %}
                                    {% if block.settings.preorder_percent != blank %}
                                        <span class="{{ section.settings.form_name }}-product-preorder_percent__{{ product_variant_id }} hide">{{ block.settings.preorder_percent }}</span>
                                    {% endif %}
                                {% endif %}

                            {% endif %}
                        {% endif %}
                    {%- endfor -%}
                
                </div>
            </div>

            {{ preorder-box-items }}
            {{ preorder_box }}

            <div class="tab-content mt-25" id="myTabContent">
                {{ product-included-dropdown }}
            </div>
        </div>
    </template>
{% endif %}